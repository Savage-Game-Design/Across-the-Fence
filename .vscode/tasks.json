{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (Mission)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' build --overwrite",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build (Server mod)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' build --overwrite --mod",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
       {
            "label": "Build (Mods with PBO packing)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' build --overwrite --mod --pack",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Launch mission dev (build, client, server)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch dev --overwrite",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch mod dev (build, client, server)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch dev --overwrite --mod",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma editor",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch client --editor",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma server",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch server",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma server (mod)",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch server --mod",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma client and connect to local server",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' launch client --connect=127.0.0.1",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        }
    ]
}
