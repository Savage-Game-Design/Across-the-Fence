{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\build.py' build --overwrite",
            "problemMatcher": [],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Launch arma client",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' client",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma server",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' server",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        },
        {
            "label": "Launch arma client and connect to local server",
            "type": "shell",
            "command": "py '${workspaceFolder}\\build\\run.py' client --connect=127.0.0.1",
            "problemMatcher": [],
            "group": {
                "kind": "none"
            }
        }
    ]
}
