#ifdef __A3_DEBUG__
    #define DEBUG_MODE_FULL
#endif

/*
    FORMAT_N macros
    used to prevent issues with commas (,) in macro arguments.
*/
#define FORMAT_1(STR,ARG1) format [STR, ARG1]
#define FORMAT_2(STR,ARG1,ARG2) format [STR, ARG1, ARG2]
#define FORMAT_3(STR,ARG1,ARG2,ARG3) format [STR, ARG1, ARG2, ARG3]
#define FORMAT_4(STR,ARG1,ARG2,ARG3,ARG4) format [STR, ARG1, ARG2, ARG3, ARG4]
#define FORMAT_5(STR,ARG1,ARG2,ARG3,ARG4,ARG5) format [STR, ARG1, ARG2, ARG3, ARG4, ARG5]
#define FORMAT_6(STR,ARG1,ARG2,ARG3,ARG4,ARG5,ARG6) format [STR, ARG1, ARG2, ARG3, ARG4, ARG5, ARG6]
#define FORMAT_7(STR,ARG1,ARG2,ARG3,ARG4,ARG5,ARG6,ARG7) format [STR, ARG1, ARG2, ARG3, ARG4, ARG5, ARG6, ARG7]
#define FORMAT_8(STR,ARG1,ARG2,ARG3,ARG4,ARG5,ARG6,ARG7,ARG8) format [STR, ARG1, ARG2, ARG3, ARG4, ARG5, ARG6, ARG7, ARG8]

#define LOG_SYS(LEVEL,MESSAGE) ([LEVEL, format ["VGM: %1", MESSAGE]] call para_g_fnc_log)

/*
    Log debug message to RPT, enabled only if full debug mode is enabled
*/
#ifdef DEBUG_MODE_FULL
    #define DEBUG(MESSAGE) LOG_SYS('DEBUG',MESSAGE)
    #define DEBUG_1(MESSAGE,VAR1) LOG_SYS('DEBUG',FORMAT_1(MESSAGE,VAR1))
    #define DEBUG_2(MESSAGE,VAR1,VAR2) LOG_SYS('DEBUG',FORMAT_2(MESSAGE,VAR1,VAR2))
    #define DEBUG_3(MESSAGE,VAR1,VAR2,VAR3) LOG_SYS('DEBUG',FORMAT_3(MESSAGE,VAR1,VAR2,VAR3))
    #define DEBUG_4(MESSAGE,VAR1,VAR2,VAR3,VAR4) LOG_SYS('DEBUG',FORMAT_4(MESSAGE,VAR1,VAR2,VAR3,VAR4))
    #define DEBUG_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5) LOG_SYS('DEBUG',FORMAT_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5))
#else
    #define DEBUG(MESSAGE) /* log disabled */
    #define DEBUG_1(MESSAGE,VAR1) /* log disabled */
    #define DEBUG_2(MESSAGE,VAR1,VAR2) /* log disabled */
    #define DEBUG_3(MESSAGE,VAR1,VAR2,VAR3) /* log disabled */
    #define DEBUG_4(MESSAGE,VAR1,VAR2,VAR3,VAR4) /* log disabled */
    #define DEBUG_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5) /* log disabled */
#endif

/*
    Log informational message to RPT
*/
#define INFO(MESSAGE) LOG_SYS('INFO',MESSAGE)
#define INFO_1(MESSAGE,VAR1) LOG_SYS('INFO',FORMAT_1(MESSAGE,VAR1))
#define INFO_2(MESSAGE,VAR1,VAR2) LOG_SYS('INFO',FORMAT_2(MESSAGE,VAR1,VAR2))
#define INFO_3(MESSAGE,VAR1,VAR2,VAR3) LOG_SYS('INFO',FORMAT_3(MESSAGE,VAR1,VAR2,VAR3))
#define INFO_4(MESSAGE,VAR1,VAR2,VAR3,VAR4) LOG_SYS('INFO',FORMAT_4(MESSAGE,VAR1,VAR2,VAR3,VAR4))
#define INFO_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5) LOG_SYS('INFO',FORMAT_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5))

/*
    Log non-critical error to RPT
*/
#define WARNING(MESSAGE) LOG_SYS('WARNING',MESSAGE)
#define WARNING_1(MESSAGE,VAR1) LOG_SYS('WARNING',FORMAT_1(MESSAGE,VAR1))
#define WARNING_2(MESSAGE,VAR1,VAR2) LOG_SYS('WARNING',FORMAT_2(MESSAGE,VAR1,VAR2))
#define WARNING_3(MESSAGE,VAR1,VAR2,VAR3) LOG_SYS('WARNING',FORMAT_3(MESSAGE,VAR1,VAR2,VAR3))
#define WARNING_4(MESSAGE,VAR1,VAR2,VAR3,VAR4) LOG_SYS('WARNING',FORMAT_4(MESSAGE,VAR1,VAR2,VAR3,VAR4))
#define WARNING_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5) LOG_SYS('WARNING',FORMAT_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5))

/*
    Log critical error to RPT
*/
#define ERROR(MESSAGE) LOG_SYS('ERROR',MESSAGE)
#define ERROR_1(MESSAGE,VAR1) LOG_SYS('ERROR',FORMAT_1(MESSAGE,VAR1))
#define ERROR_2(MESSAGE,VAR1,VAR2) LOG_SYS('ERROR',FORMAT_2(MESSAGE,VAR1,VAR2))
#define ERROR_3(MESSAGE,VAR1,VAR2,VAR3) LOG_SYS('ERROR',FORMAT_3(MESSAGE,VAR1,VAR2,VAR3))
#define ERROR_4(MESSAGE,VAR1,VAR2,VAR3,VAR4) LOG_SYS('ERROR',FORMAT_4(MESSAGE,VAR1,VAR2,VAR3,VAR4))
#define ERROR_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5) LOG_SYS('ERROR',FORMAT_5(MESSAGE,VAR1,VAR2,VAR3,VAR4,VAR5))
