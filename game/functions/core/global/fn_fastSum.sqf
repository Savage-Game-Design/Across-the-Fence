#define ONES_LENGTH 1000

private _values = _this;

if (count _values > ONES_LENGTH ) exitWith {
    [format ["Attempted to fastSum with extremely large array (%1 items). Using slow sum. This will be very very slow.", count _values]] call vgm_g_fnc_logWarning;
    private _total = 0;
    {
        _total = _total + _x;
    } forEach _values;
    _total
};

_values vectorDotProduct (ONES select [0, count _values])
